{
  "name": "korovany",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "КОРОВАНЫ — 3D action game. Эльфы, охрана дворца, злодеи. Можно грабить корованы.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "assets:fetch": "bash scripts/fetch-assets.sh",
    "assets:prepare": "node scripts/prepare-assets.mjs",
    "assets:check": "node scripts/check-assets.mjs"
  },
  "dependencies": {
    "@dimforge/rapier3d-compat": "0.19.3",
    "postprocessing": "6.39.1",
    "three": "0.184.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.2.0",
    "@types/node": "^24.13.1",
    "@types/three": "0.180.0",
    "lil-gui": "0.21.0",
    "typescript": "^5.9.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0"
  }
}
